# Get a free API key at https://openrouter.ai/keys
# The free model tier (qwen-2.5-72b-instruct) requires no credits/payment
NEXT_PUBLIC_OPENROUTER_API_KEY=sk-or-v1-...

# 3D Generation API Keys (optional)
# Meshy.ai - text-to-3D (https://meshy.ai)
MESHY_API_KEY=

# Tripo AI - text/image-to-3D (https://tripoml.com)
TRIPO_API_KEY=

# Generation mode: "ai" (Hunyuan3D) or "procedural" (fallback)
# Default is "ai" with automatic fallback to procedural
NEXT_PUBLIC_3D_GENERATION_MODE=ai
